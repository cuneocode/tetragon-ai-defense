# Cisco AI Defense Inspection API
# Get your key from: https://developer.cisco.com/docs/ai-defense-inspection/introduction/
AIDEFENSE_API_KEY=your_api_key_here

# Optional: OpenAI key if proxying to OpenAI
#OPENAI_API_KEY=sk-...

# Region: "us" (default) or "eu" or "ap"
AIDEFENSE_REGION=us

# Shim port (OpenClaw points here)
PORT=9000

# Upstream LLM — swap these two lines to switch between backends:
UNDERLYING_LLM_BASE_URL=http://127.0.0.1:8000/v1
#UNDERLYING_LLM_BASE_URL=https://api.openai.com/v1
